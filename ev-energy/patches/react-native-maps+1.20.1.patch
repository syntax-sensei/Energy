+  @Override
+  protected void onLayout(boolean changed, int l, int t, int r, int b) {
+    super.onLayout(changed, l, t, r, b);
+
+    // On Fabric, the Yoga layout box reported to updateExtraData() can be smaller
+    // than the marker's actual laid-out subtree, which produces an undersized
+    // bitmap and a clipped/cropped custom marker icon on Android only (iOS hosts
+    // the view live and isn't affected). Recompute from the real laid-out bounds
+    // here and refresh the bitmap whenever they change.
+    int newWidth = r - l;
+    int newHeight = b - t;
+    if (newWidth > 0 && newHeight > 0 && (newWidth != this.width || newHeight != this.height)) {
+      this.width = newWidth;
+      this.height = newHeight;
+
+      clearDrawableCache();
+      if (marker != null) {
+        update(true);
+      }
+    }
+  }
+
   @Override
   public Object getFeature() {
     return marker;
